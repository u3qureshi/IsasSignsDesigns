# Copy this file to .env and fill secrets locally. Never commit real secrets.

APP_TIME_ZONE=America/Toronto
CUSTOM_EMBROIDERY_MAX_UPLOAD_BYTES=10485760
CUSTOM_EMBROIDERY_ALLOWED_IMAGE_TYPES=image/png,image/jpeg,image/webp

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_rotated_cloudflare_api_token
CLOUDFLARE_AI_MODEL=@cf/black-forest-labs/flux-2-klein-4b

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_DELIVERY_TYPE=authenticated

CUSTOM_EMBROIDERY_HMAC_SECRET=generate_a_long_random_secret

# Customer confirmation + Thread & Butter admin notifications.
# Keep both flags false until the corresponding credentials are complete.
THREAD_AND_BUTTER_ADMIN_EMAIL=you@example.com
THREAD_AND_BUTTER_ADMIN_PHONE=+14165551234

EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_FROM_ADDRESS=orders@your-domain.example
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password_or_app_password
SMTP_AUTH=true
SMTP_STARTTLS_ENABLED=true

SMS_NOTIFICATIONS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+14165551234
